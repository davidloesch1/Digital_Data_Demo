# Copy to .env locally (do not commit .env) and run: export $(grep -v '^#' .env | xargs) && npm run build
# Vercel: set the same names under Project → Environment Variables.

# Required for org mode (injected into js/nexus-env.secrets.js at build time)
NEXUS_PUBLISHABLE_KEY=nx_pub_replace_me
NEXUS_API_BASE=https://your-collector.up.railway.app

# Optional overrides (same host as NEXUS_API_BASE if unset)
# NEXUS_COLLECT_BASE=https://...
# NEXUS_DASH_API=https://...

# --- Magic link auth (Vercel serverless /api/* only — set in Vercel dashboard, not injected into client JS)
# NEXUS_COLLECTOR_ORIGIN=https://your-collector.up.railway.app
# CONSOLE_BFF_SECRET=long-random-match-collector
# CONSOLE_PUBLIC_URL=https://your-console.vercel.app
# RESEND_API_KEY=re_...
# RESEND_FROM="Nexus <login@yourdomain.com>"
# RESEND_MAGIC_SUBJECT=Your Nexus Console login link
